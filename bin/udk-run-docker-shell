#!/bin/bash -e
# Script to facilitate login to a docker container's shell

DOCKER_IMG=$1

if [ -z "$DOCKER_IMG" ]; then
  echo -e "Usage: $(basename $0) <docker-image-to-launch>"
  exit 1
fi

if [ -e "/bin/bash" ]; then
  docker run --rm -ti $DOCKER_IMG /bin/bash
else
  docker run --rm -ti $DOCKER_IMG /bin/sh
fi

exit 0
